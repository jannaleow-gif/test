<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Marquee Singapore — CRM Strategy Presentation</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Cormorant+Garamond:wght@300;400;600&family=Rajdhani:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');

  :root {
    --deep-purple: #0d0618;
    --mid-purple: #1a0a2e;
    --rich-purple: #2d1155;
    --accent-purple: #4a1a8a;
    --silver: #c8c8d4;
    --silver-bright: #e8e8f0;
    --silver-dim: #8888a0;
    --gold: #b8960c;
    --gold-light: #d4af37;
    --white: #f0f0f8;
    --red-alert: #e83a5a;
    --teal-accent: #1a8a7a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--deep-purple);
    font-family: 'Rajdhani', sans-serif;
    color: var(--white);
    overflow-x: hidden;
  }

  /* ─── NAV ─── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 40px;
    background: rgba(13,6,24,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(200,200,212,0.15);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 18px; font-weight: 700; letter-spacing: 0.2em;
    color: var(--gold-light); text-transform: uppercase;
  }
  .nav-dots { display: flex; gap: 8px; align-items: center; }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--silver-dim); cursor: pointer;
    transition: all 0.3s ease;
  }
  .dot.active { background: var(--gold-light); transform: scale(1.4); }
  .nav-counter {
    font-family: 'Space Mono', monospace;
    font-size: 12px; color: var(--silver-dim); letter-spacing: 0.1em;
  }

  /* ─── SLIDES ─── */
  .slides-container { }
  .slide {
    min-height: 100vh;
    padding: 100px 60px 60px;
    display: none;
    position: relative;
    overflow: hidden;
    animation: slideIn 0.5s ease;
  }
  .slide.active { display: flex; flex-direction: column; }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── BACKGROUND EFFECTS ─── */
  .bg-glow {
    position: absolute; border-radius: 50%;
    filter: blur(120px); pointer-events: none; z-index: 0;
  }
  .glow-1 { width: 600px; height: 600px; background: rgba(74,26,138,0.15); top: -200px; right: -100px; }
  .glow-2 { width: 400px; height: 400px; background: rgba(184,150,12,0.06); bottom: 0; left: 0; }
  .glow-red { background: rgba(232,58,90,0.1); width: 300px; height: 300px; top: 20%; left: -100px; }

  .slide-content { position: relative; z-index: 1; flex: 1; display: flex; flex-direction: column; }

  /* ─── SECTION LABELS ─── */
  .section-label {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold-light); margin-bottom: 16px;
  }
  .section-label::before {
    content: ''; width: 30px; height: 1px; background: var(--gold-light);
  }

  .section-label.silver { color: var(--silver); }
  .section-label.silver::before { background: var(--silver); }
  .section-label.red { color: var(--red-alert); }
  .section-label.red::before { background: var(--red-alert); }

  /* ─── HEADINGS ─── */
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 900; line-height: 1.05;
    color: var(--white);
  }
  h1 span { color: var(--gold-light); }
  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 700; line-height: 1.1;
    color: var(--white);
  }
  h2 span { color: var(--gold-light); }
  h3 {
    font-family: 'Rajdhani', sans-serif;
    font-size: 20px; font-weight: 600; letter-spacing: 0.05em;
    color: var(--silver-bright);
  }
  .slide-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; color: var(--silver); margin-top: 12px;
    font-style: italic; line-height: 1.5;
  }

  /* ─── DIVIDER ─── */
  .divider {
    width: 60px; height: 2px;
    background: linear-gradient(90deg, var(--gold-light), transparent);
    margin: 20px 0;
  }
  .divider.full { width: 100%; margin: 28px 0; background: linear-gradient(90deg, rgba(200,200,212,0.2), transparent); height: 1px; }

  /* ─── STAT BOXES ─── */
  .stat-row { display: flex; gap: 20px; margin: 20px 0; flex-wrap: wrap; }
  .stat-box {
    flex: 1; min-width: 150px;
    background: rgba(45,17,85,0.4);
    border: 1px solid rgba(200,200,212,0.15);
    border-radius: 8px; padding: 20px 24px;
    position: relative; overflow: hidden;
    transition: border-color 0.3s;
  }
  .stat-box::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--gold-light), transparent);
  }
  .stat-box.danger::before { background: linear-gradient(90deg, var(--red-alert), transparent); }
  .stat-box.silver-top::before { background: linear-gradient(90deg, var(--silver), transparent); }
  .stat-number {
    font-family: 'Space Mono', monospace;
    font-size: 36px; font-weight: 700; line-height: 1;
    color: var(--gold-light);
  }
  .stat-box.danger .stat-number { color: var(--red-alert); }
  .stat-box.silver-top .stat-number { color: var(--silver-bright); }
  .stat-label { font-size: 13px; color: var(--silver-dim); margin-top: 6px; letter-spacing: 0.05em; }
  .stat-source { font-size: 11px; color: rgba(136,136,160,0.6); margin-top: 4px; font-style: italic; }

  /* ─── CARDS ─── */
  .cards-grid { display: grid; gap: 16px; margin-top: 20px; }
  .cards-grid.two { grid-template-columns: repeat(2, 1fr); }
  .cards-grid.three { grid-template-columns: repeat(3, 1fr); }
  .cards-grid.four { grid-template-columns: repeat(4, 1fr); }

  .card {
    background: rgba(26,10,46,0.6);
    border: 1px solid rgba(200,200,212,0.12);
    border-radius: 10px; padding: 22px;
    transition: border-color 0.3s, transform 0.2s;
  }
  .card:hover { border-color: rgba(212,175,55,0.35); transform: translateY(-2px); }
  .card-icon { font-size: 24px; margin-bottom: 10px; }
  .card-title {
    font-size: 15px; font-weight: 600; letter-spacing: 0.05em;
    color: var(--silver-bright); margin-bottom: 8px;
  }
  .card-body { font-size: 14px; color: var(--silver-dim); line-height: 1.6; }
  .card-tag {
    display: inline-block; margin-top: 10px;
    font-family: 'Space Mono', monospace; font-size: 10px;
    padding: 3px 10px; border-radius: 30px;
    background: rgba(74,26,138,0.4); border: 1px solid rgba(212,175,55,0.3);
    color: var(--gold-light); letter-spacing: 0.1em;
  }
  .card-tag.danger { background: rgba(232,58,90,0.1); border-color: rgba(232,58,90,0.3); color: var(--red-alert); }
  .card-tag.silver { background: rgba(200,200,212,0.08); border-color: rgba(200,200,212,0.2); color: var(--silver); }

  /* ─── CHALLENGE BARS ─── */
  .challenge-item { margin-bottom: 18px; }
  .challenge-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .challenge-name { font-size: 15px; font-weight: 600; color: var(--silver-bright); }
  .challenge-beta {
    font-family: 'Space Mono', monospace; font-size: 13px; color: var(--gold-light);
  }
  .bar-track {
    height: 6px; background: rgba(200,200,212,0.1); border-radius: 3px; overflow: hidden;
  }
  .bar-fill { height: 100%; border-radius: 3px; transition: width 1s ease; }
  .bar-music { background: linear-gradient(90deg, var(--gold-light), #d4af37cc); width: 85%; }
  .bar-service { background: linear-gradient(90deg, var(--red-alert), #e83a5acc); width: 57%; }
  .bar-price { background: linear-gradient(90deg, var(--silver), #c8c8d488); width: 47%; }
  .challenge-desc { font-size: 13px; color: var(--silver-dim); margin-top: 6px; }

  /* ─── LOYALTY MODEL ─── */
  .loyalty-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3px;
    margin: 20px 0; border: 1px solid rgba(200,200,212,0.15); border-radius: 10px; overflow: hidden;
  }
  .loyalty-cell {
    padding: 20px; text-align: center; position: relative;
  }
  .lc-loyals { background: rgba(26,138,122,0.2); }
  .lc-latent { background: rgba(74,26,138,0.2); }
  .lc-spurious { background: rgba(184,150,12,0.15); }
  .lc-noloyalty { background: rgba(232,58,90,0.15); }
  .loyalty-cell-title { font-weight: 700; font-size: 16px; }
  .loyalty-cell-pct { font-family: 'Space Mono', monospace; font-size: 22px; font-weight: 700; margin: 4px 0; }
  .loyalty-cell-desc { font-size: 12px; color: var(--silver-dim); }
  .lc-loyals .loyalty-cell-pct { color: #4dc4b0; }
  .lc-latent .loyalty-cell-pct { color: #9a6bda; }
  .lc-spurious .loyalty-cell-pct { color: var(--gold-light); }
  .lc-noloyalty .loyalty-cell-pct { color: var(--red-alert); }
  .loyalty-axis-x { text-align: center; font-size: 11px; color: var(--silver-dim); margin-top: 6px; letter-spacing: 0.08em; }
  .loyalty-axis-label { font-size: 11px; color: var(--silver-dim); letter-spacing: 0.08em; }

  /* ─── TWO COL ─── */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 24px; }
  .two-col.wide { grid-template-columns: 1.3fr 1fr; }

  /* ─── PIPELINE / PHASE ─── */
  .phase-row { display: flex; gap: 0; margin: 20px 0; }
  .phase-step {
    flex: 1; padding: 18px 20px;
    position: relative; background: rgba(26,10,46,0.5);
    border-top: 2px solid rgba(200,200,212,0.15);
  }
  .phase-step::after {
    content: '▶'; position: absolute; right: -12px; top: 50%; transform: translateY(-50%);
    color: var(--silver-dim); font-size: 12px; z-index: 2;
  }
  .phase-step:last-child::after { display: none; }
  .phase-step:first-child { border-radius: 8px 0 0 8px; border-top-color: var(--gold-light); }
  .phase-step.p2 { border-top-color: var(--silver); }
  .phase-step.p3 { border-top-color: #9a6bda; border-radius: 0 8px 8px 0; }
  .phase-num { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--silver-dim); letter-spacing: 0.1em; margin-bottom: 6px; }
  .phase-title { font-size: 14px; font-weight: 600; color: var(--silver-bright); margin-bottom: 6px; }
  .phase-body { font-size: 12px; color: var(--silver-dim); line-height: 1.5; }

  /* ─── INSIGHT CALLOUT ─── */
  .callout {
    background: rgba(184,150,12,0.08);
    border-left: 3px solid var(--gold-light);
    border-radius: 0 8px 8px 0;
    padding: 14px 18px; margin: 16px 0;
    font-size: 14px; color: var(--silver); line-height: 1.6;
  }
  .callout.red { background: rgba(232,58,90,0.08); border-left-color: var(--red-alert); }
  .callout strong { color: var(--white); }

  /* ─── GAP INDICATORS ─── */
  .gap-row { display: flex; gap: 12px; margin: 14px 0; flex-wrap: wrap; }
  .gap-pill {
    display: flex; align-items: center; gap: 8px;
    background: rgba(232,58,90,0.1); border: 1px solid rgba(232,58,90,0.25);
    border-radius: 30px; padding: 6px 14px;
    font-size: 13px; color: var(--silver-bright);
  }
  .gap-pill-num { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--red-alert); }

  /* ─── RECOMMENDATION HEADER ─── */
  .rec-header {
    display: flex; align-items: center; gap: 16px; margin-bottom: 20px;
  }
  .rec-icon-circle {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(74,26,138,0.4);
    border: 1px solid rgba(212,175,55,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0;
  }
  .rec-title-block h2 { font-size: 30px; }

  /* ─── APP FEATURES ─── */
  .app-features { display: flex; flex-direction: column; gap: 10px; }
  .app-feature {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 12px 16px; border-radius: 8px;
    background: rgba(45,17,85,0.3); border: 1px solid rgba(200,200,212,0.08);
  }
  .af-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }
  .af-title { font-size: 14px; font-weight: 600; color: var(--silver-bright); }
  .af-body { font-size: 13px; color: var(--silver-dim); margin-top: 2px; }

  /* ─── ROADMAP ─── */
  .roadmap { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin: 20px 0; }
  .roadmap-phase { padding: 20px; border-top: 2px solid; }
  .rp-1 { border-color: var(--gold-light); }
  .rp-2 { border-color: var(--silver); }
  .rp-3 { border-color: #9a6bda; }
  .rp-period { font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.1em; margin-bottom: 8px; }
  .rp-1 .rp-period { color: var(--gold-light); }
  .rp-2 .rp-period { color: var(--silver); }
  .rp-3 .rp-period { color: #9a6bda; }
  .rp-title { font-size: 15px; font-weight: 700; color: var(--silver-bright); margin-bottom: 10px; }
  .rp-items { display: flex; flex-direction: column; gap: 6px; }
  .rp-item { font-size: 13px; color: var(--silver-dim); display: flex; gap: 8px; }
  .rp-item::before { content: '—'; color: var(--silver-dim); flex-shrink: 0; }

  /* ─── TRAINING SCENES ─── */
  .scene-table { width: 100%; border-collapse: collapse; margin-top: 16px; }
  .scene-table th {
    text-align: left; padding: 10px 14px;
    font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.1em;
    color: var(--gold-light); border-bottom: 1px solid rgba(212,175,55,0.3);
  }
  .scene-table td {
    padding: 10px 14px; font-size: 13px; color: var(--silver-dim);
    border-bottom: 1px solid rgba(200,200,212,0.07); vertical-align: top; line-height: 1.5;
  }
  .scene-table tr:hover td { background: rgba(74,26,138,0.15); }
  .scene-highlight { color: var(--silver-bright); font-weight: 600; }

  /* ─── VIP TIER ─── */
  .vip-tier-row { display: flex; gap: 16px; margin: 20px 0; }
  .vip-tier {
    flex: 1; padding: 20px; border-radius: 10px;
    background: rgba(26,10,46,0.6);
    border: 1px solid rgba(200,200,212,0.1);
    position: relative; overflow: hidden;
  }
  .vt-diamond { border-top: 3px solid var(--gold-light); }
  .vt-ruby { border-top: 3px solid var(--red-alert); }
  .vt-title { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; margin-bottom: 6px; }
  .vt-diamond .vt-title { color: var(--gold-light); }
  .vt-ruby .vt-title { color: var(--red-alert); }
  .vt-desc { font-size: 13px; color: var(--silver-dim); margin-bottom: 12px; }
  .vt-perk { display: flex; gap: 8px; align-items: flex-start; margin-bottom: 6px; font-size: 13px; color: var(--silver); }
  .vt-perk::before { content: '◆'; font-size: 8px; color: var(--gold-light); margin-top: 4px; flex-shrink: 0; }
  .vt-ruby .vt-perk::before { color: var(--red-alert); }

  /* ─── NAVIGATION BUTTONS ─── */
  .slide-nav {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: auto; padding-top: 30px;
  }
  .btn {
    padding: 10px 28px; border-radius: 4px; cursor: pointer;
    font-family: 'Rajdhani', sans-serif; font-size: 14px;
    font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    border: none; transition: all 0.25s ease; text-decoration: none;
  }
  .btn-outline {
    background: transparent; color: var(--silver);
    border: 1px solid rgba(200,200,212,0.25);
  }
  .btn-outline:hover { border-color: var(--silver); color: var(--white); }
  .btn-gold {
    background: var(--gold-light); color: var(--deep-purple);
  }
  .btn-gold:hover { background: #e8c84a; }
  .btn-hidden { visibility: hidden; }
  .slide-num {
    font-family: 'Space Mono', monospace; font-size: 12px; color: var(--silver-dim);
  }

  /* ─── COVER ─── */
  .cover-layout {
    min-height: 100vh; display: flex; flex-direction: column;
    justify-content: center; align-items: flex-start; padding: 0 60px;
    position: relative; overflow: hidden;
  }
  .cover-line {
    width: 1px; height: 120px; background: linear-gradient(180deg, transparent, var(--gold-light), transparent);
    position: absolute; left: 40px; top: 50%; transform: translateY(-50%);
  }
  .cover-eyebrow {
    font-family: 'Space Mono', monospace; font-size: 11px;
    letter-spacing: 0.3em; color: var(--gold-light); text-transform: uppercase;
    margin-bottom: 20px;
  }
  .cover-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(48px, 7vw, 90px);
    font-weight: 900; line-height: 0.95;
    color: var(--white);
  }
  .cover-title .highlight { color: var(--gold-light); display: block; }
  .cover-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-style: italic;
    color: var(--silver); margin-top: 20px; max-width: 600px; line-height: 1.5;
  }
  .cover-meta { display: flex; gap: 40px; margin-top: 40px; flex-wrap: wrap; }
  .cover-meta-item { font-size: 13px; color: var(--silver-dim); }
  .cover-meta-item strong { color: var(--silver); display: block; font-size: 14px; }
  .cover-decoration {
    position: absolute; right: 60px; top: 50%; transform: translateY(-50%);
    width: 300px; height: 300px; border-radius: 50%;
    border: 1px solid rgba(212,175,55,0.12);
    display: flex; align-items: center; justify-content: center;
  }
  .cover-decoration::before {
    content: ''; width: 220px; height: 220px; border-radius: 50%;
    border: 1px solid rgba(212,175,55,0.08); position: absolute;
  }
  .cover-decoration::after {
    content: 'M'; font-family: 'Playfair Display', serif;
    font-size: 120px; font-weight: 900;
    color: rgba(212,175,55,0.08);
  }

  /* ─── SECTION DIVIDER SLIDE ─── */
  .section-divider-slide {
    background: linear-gradient(135deg, #0d0618 0%, #1a0a2e 50%, #0d0618 100%);
    justify-content: center; align-items: center; text-align: center;
  }
  .sd-label {
    font-family: 'Space Mono', monospace; font-size: 11px;
    letter-spacing: 0.4em; color: var(--gold-light); margin-bottom: 16px;
  }
  .sd-number {
    font-family: 'Playfair Display', serif; font-size: 140px; font-weight: 900;
    color: rgba(212,175,55,0.05); position: absolute;
    top: 50%; transform: translateY(-50%);
  }
  .sd-title { font-family: 'Playfair Display', serif; font-size: 60px; font-weight: 900; }
  .sd-subtitle { font-size: 18px; color: var(--silver-dim); margin-top: 16px; max-width: 500px; }

  /* ─── SUMMARY BOX ─── */
  .summary-row { display: flex; gap: 16px; margin-top: 20px; }
  .summary-pill {
    flex: 1; padding: 16px 20px; border-radius: 8px;
    background: rgba(26,10,46,0.6);
    border: 1px solid rgba(200,200,212,0.12);
    font-size: 14px; color: var(--silver);
    display: flex; flex-direction: column; gap: 6px;
  }
  .sp-label { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.15em; color: var(--silver-dim); }
  .sp-value { font-size: 20px; font-weight: 700; color: var(--white); }
  .sp-value.gold { color: var(--gold-light); }
  .sp-value.red { color: var(--red-alert); }

  /* ─── MISER MATRIX ─── */
  .matrix-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3px;
    background: rgba(200,200,212,0.08); border-radius: 10px; overflow: hidden;
    margin: 16px 0;
  }
  .mx-cell { padding: 18px; background: var(--deep-purple); }
  .mx-miser { background: rgba(232,58,90,0.12); }
  .mx-advocate { background: rgba(26,138,122,0.12); }
  .mx-affluent { background: rgba(184,150,12,0.12); }
  .mx-champion { background: rgba(74,26,138,0.25); }
  .mx-label { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.12em; color: var(--silver-dim); margin-bottom: 4px; }
  .mx-title { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .mx-pct { font-family: 'Space Mono', monospace; font-size: 24px; font-weight: 700; margin-bottom: 4px; }
  .mx-desc { font-size: 12px; color: var(--silver-dim); }
  .mx-miser .mx-title, .mx-miser .mx-pct { color: var(--red-alert); }
  .mx-advocate .mx-title, .mx-advocate .mx-pct { color: #4dc4b0; }
  .mx-affluent .mx-title, .mx-affluent .mx-pct { color: var(--gold-light); }
  .mx-champion .mx-title, .mx-champion .mx-pct { color: #9a6bda; }

